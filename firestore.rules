rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // EXISTING USER RULES (unchanged)
    // ============================================================

    // User profile documents — public read for community stats
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      // User data subcollection (matches, owned-sets, matches-meta, groups, group-invites)
      match /data/{docId} {
        // 'matches' is public read for community stats (getAllUserMatches)
        // All other docs (owned-sets, matches-meta, groups, group-invites) are owner-only read
        allow read: if docId == 'matches'
                    || (request.auth != null && request.auth.uid == userId);
        allow write: if request.auth != null && (request.auth.uid == userId || docId == 'group-invites');
      }

      // Individual match subcollection (for migration to subcollection model)
      match /matches/{matchId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============================================================
    // PENDING EMAIL INVITES
    // ============================================================

    match /pending-email-invites/{email} {
      allow read, write: if request.auth != null;
    }

    // ============================================================
    // GAME GROUPS RULES
    // ============================================================

    match /groups/{groupId} {

      // --- Helper functions ---

      function isAuthenticated() {
        return request.auth != null;
      }

      function isMember() {
        return isAuthenticated()
            && request.auth.uid in resource.data.memberUids;
      }

      function isMemberOfGroup() {
        return isAuthenticated()
            && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
      }

      function isOwner() {
        return isAuthenticated()
            && resource.data.ownerUid == request.auth.uid;
      }

      function isOwnerOfGroup() {
        return isAuthenticated()
            && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid == request.auth.uid;
      }

      function isAdminOrOwner() {
        return isAuthenticated()
            && (
              get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid == request.auth.uid
              || get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']
            );
      }

      // --- Group document rules ---

      // Read: only members can read group details
      allow read: if isMember();

      // Create: any authenticated user can create a group
      // The creator must set themselves as owner and include themselves in memberUids
      allow create: if isAuthenticated()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.auth.uid in request.resource.data.memberUids;

      // Update: only owner can update group settings
      // (memberUids changes also require owner — enforced by ownerUid check)
      allow update: if isOwner();

      // Delete: only owner can delete the group
      allow delete: if isOwner();

      // --- Group matches subcollection ---

      match /matches/{matchId} {
        // Read: any group member can read matches
        allow read: if isMemberOfGroup();

        // Create: any group member can log a match, but loggedBy must be their uid
        allow create: if isMemberOfGroup()
                      && request.resource.data.loggedBy == request.auth.uid;

        // Update: only the user who logged the match can edit it
        allow update: if isAuthenticated()
                      && resource.data.loggedBy == request.auth.uid;

        // Delete: only the user who logged the match can delete it
        allow delete: if isAuthenticated()
                      && resource.data.loggedBy == request.auth.uid;
      }

      // --- Group members subcollection ---

      match /members/{memberId} {
        // Read: any group member can see membership info
        allow read: if isMemberOfGroup();

        // Create: owner/admin can add members, OR a user can bootstrap their own
        // owner membership doc during group creation (batch creates group + member atomically,
        // but get() in isAdminOrOwner sees pre-batch state where group doesn't exist yet)
        allow create: if isAdminOrOwner()
                      || (isAuthenticated()
                          && memberId == request.auth.uid
                          && request.resource.data.role == 'owner');

        // Update/Delete: only owner or admin can manage members
        allow update, delete: if isAdminOrOwner();
      }

      // --- Group invites subcollection ---

      match /invites/{inviteId} {
        // Read: group members can see invites, OR the invitee can see their own invite
        allow read: if isMemberOfGroup()
                    || (isAuthenticated() && resource.data.invitedUid == request.auth.uid);

        // Create: any group member can create an invite
        allow create: if isMemberOfGroup();

        // Update: invitee can accept/decline, OR owner/admin can modify
        allow update: if (isAuthenticated() && resource.data.invitedUid == request.auth.uid)
                      || isAdminOrOwner();

        // Delete: invitee can decline (delete), OR owner/admin can cancel
        allow delete: if (isAuthenticated() && resource.data.invitedUid == request.auth.uid)
                      || isAdminOrOwner();
      }
    }
  }
}
